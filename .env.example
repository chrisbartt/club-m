# =============================================================================
# Club M — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# =============================================================================

# Gate (mot de passe d'acces au site en pre-launch)
NEXT_PUBLIC_GATE_PASSWORD=

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/clubm"

# Auth (generer avec: openssl rand -base64 32)
AUTH_SECRET=
AUTH_TRUST_HOST=true

# URL publique de l'application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=https://clubm.cd

# Cloudinary (server-side)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudinary (client-side upload)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=clubm_uploads

# Admin
ADMIN_EMAIL=admin@clubm.cd

# Email (Resend — https://resend.com)
RESEND_API_KEY=

# Paiement (ARAKA — https://arakapay.com)
PAYMENT_PROVIDER=araka
ARAKA_API_URL=https://araka-api-uat.azurewebsites.net
ARAKA_EMAIL=
ARAKA_PASSWORD=
ARAKA_PAYMENT_PAGE_ID=
